<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Projekt.AddEmployeePage"
             Title="Dodaj pracownika">

    <VerticalStackLayout Padding="20" Spacing="15">
        <Entry Placeholder="Imię" Text="{Binding FirstName}" />
        <Entry Placeholder="Nazwisko" Text="{Binding LastName}" />
        <Entry Placeholder="PESEL/Nr ewidencyjny" Text="{Binding ReferenceNumber}" />

        <Label Text="Data zatrudnienia:" Margin="0,10,0,0" />
        <DatePicker Date="{Binding EmploymentDate}" />

        <Label Text="Typ zatrudnienia:" Margin="0,10,0,0" />
        <Picker ItemsSource="{Binding EmploymentTypes}"
                ItemDisplayBinding="{Binding Name}"
                SelectedItem="{Binding SelectedType}" />

        <Button Text="Zapisz pracownika" 
                Command="{Binding SaveCommand}"
                BackgroundColor="{StaticResource Primary}"
                TextColor="White"
                Margin="0,20,0,0" />
    </VerticalStackLayout>
</ContentPage>